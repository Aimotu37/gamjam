  dialogue:
    lines:
    - speaker: 1
      portrait: 12
      text: "\u770B\u89C1\u7535\u8111\u611F\u89C9\u6211\u7684\u4EF7\u503C\u53EA\u6709\u5DE5\u4F5C\u3002"
    - speaker: 1
      portrait: 12
      text: "\u4ECE\u524D\u7684\u81EA\u5DF1\u597D\u50CF\u4ECE\u6765\u6CA1\u6709\u8FD9\u6837\u60F3\u8FC7\u3002"
